# Shared image for the two Dockerized MCP tool servers (architecture.md §7:
# "Each MCP tool server containerized independently so a broken search integration
# doesn't require redeploying the whole pipeline"). Same dependency set covers both
# mcp_search_server.py and mcp_extract_server.py; docker-compose.yml selects which one
# to run per-service via `command:`.
FROM python:3.12-slim

WORKDIR /app

RUN apt-get update && apt-get install -y --no-install-recommends \
    build-essential \
    && rm -rf /var/lib/apt/lists/*

COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

COPY research_langgraph/ ./research_langgraph/

ENV PYTHONPATH=/app \
    PYTHONUNBUFFERED=1

# Overridden per-service in docker-compose.yml.
CMD ["uvicorn", "research_langgraph.tools.mcp_search_server:app", "--host", "0.0.0.0", "--port", "8001"]
