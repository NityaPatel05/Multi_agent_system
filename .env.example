# Model providers (routing/model_tiers.py) — Groq primary, Gemini fallback per tier.
GROQ_API_KEY=
GOOGLE_API_KEY=
# GEMINI_API_KEY also works as an alias for GOOGLE_API_KEY

# Search adapter (tools/mcp_search_adapter.py) — Exa primary, Tavily fallback.
EXA_API_KEY=
TAVILY_API_KEY=

# All of the above are optional: with none configured, the graph runs end-to-end on
# deterministic offline mocks (see the "self-healing fallback chain" comments in
# routing/model_router.py and tools/mcp_*_adapter.py).

# Checkpointer (memory/checkpointer.py) — Postgres in production; omit for an in-memory
# checkpointer during local dev/smoke tests (does not survive a process restart).
# Under docker-compose this is set automatically to point at the postgres service —
# only fill this in for a non-Docker Postgres instance.
DATABASE_URL=
# Password for the docker-compose postgres service (used to build DATABASE_URL above).
POSTGRES_PASSWORD=research

# Episodic memory (memory/episodic_store.py) — Qdrant; omit for a local on-disk JSON store.
QDRANT_URL=
EMBEDDING_PROVIDER=
EPISODIC_STORE_PATH=.episodic_store.json

# Observability (observability/langsmith_setup.py)
LANGSMITH_API_KEY=

# Dockerized MCP tool servers (tools/mcp_search_server.py, mcp_extract_server.py;
# architecture.md §7) — tools/mcp_orchestrator.py dispatches over HTTP when these are
# set, and self-heals back to in-process adapter calls if the server is unreachable.
# Under docker-compose these are set automatically to point at the mcp-search/
# mcp-extract services — leave blank for local (non-Docker) runs, which call the
# adapters in-process exactly as before.
MCP_SEARCH_URL=
MCP_EXTRACT_URL=
MCP_HTTP_TIMEOUT=20

# Parallel fan-out concurrency caps (routing/model_router.py) — keep under your free-tier
# requests/min limit.
GROQ_MAX_CONCURRENCY=4
GEMINI_MAX_CONCURRENCY=4

# docker-compose host-side port overrides (container-internal ports are fixed and
# unaffected by these — see docker-compose.yml). Defaults were chosen to avoid the most
# common local collisions (5432/6333/8001 are popular defaults for other projects'
# postgres/qdrant/redis); override any of these if they still collide on your machine.
API_HOST_PORT=8000
POSTGRES_HOST_PORT=5433
QDRANT_HOST_PORT=6343
MCP_SEARCH_HOST_PORT=8011
MCP_EXTRACT_HOST_PORT=8012
